# Скопируйте этот файл в .env для локального запуска и заполните значениями.
# На Railway эти же переменные задаются в разделе Variables вашего сервиса —
# отдельный .env файл там не нужен.
# НИКОГДА не публикуйте .env или реальные значения в открытом репозитории.

# Секретный ключ, который телефон должен присылать в заголовке x-api-key.
# Сгенерировать: openssl rand -hex 32
API_KEY=123

# Порт (Railway подставит свой автоматически через переменную PORT)
PORT=3000

# Имя "пользователя" в таблице users (для однопользовательского сайта)
STATUS_USERNAME=sky

# Через сколько секунд без heartbeat статус автоматически станет "offline"
OFFLINE_AFTER_SECONDS=180

# Строка подключения к PostgreSQL (в Railway можно сослаться на переменную
# базы данных: ${{Postgres.DATABASE_URL}} — см. инструкцию ниже)
DATABASE_URL=postgresql://postgres:jbDnMTfRCvXMlzSeqPRKzflYfENIlTvh@metro.proxy.rlwy.net:21532/railway
